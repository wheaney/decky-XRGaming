#!/usr/bin/env bash

# exit when any command fails, treat unset vars as errors
set -euo pipefail

# check that a version is provided as the first parameter
if [ -z "$1" ]
then
  echo "Usage: $0 <breezyVersion>"
  exit 1
fi

tmpdir=$(mktemp -d)
cleanup() {
  rm -rf "${tmpdir}"
}
trap cleanup EXIT

version=$1
echo "Using breezy version: ${version}"

owner="wheaney"
repo="breezy-desktop"
apiUrl="https://api.github.com/repos/${owner}/${repo}/releases/tags/${version}"

curl_headers=(
  -H "Accept: application/vnd.github+json"
  -H "X-GitHub-Api-Version: 2022-11-28"
)

token="${GITHUB_TOKEN:-${GH_TOKEN:-}}"
if [ -n "${token}" ]; then
  curl_headers+=( -H "Authorization: Bearer ${token}" )
fi

releaseJson="$(curl -sS -L "${curl_headers[@]}" "${apiUrl}")"

asset_url() {
  local assetName="$1"
  echo "${releaseJson}" | jq -r --arg name "${assetName}" '.assets[] | select(.name == $name) | .browser_download_url' | head -n 1
}

asset_digest() {
  local assetName="$1"
  echo "${releaseJson}" | jq -r --arg name "${assetName}" '.assets[] | select(.name == $name) | (.digest // "")' | head -n 1
}

sha256_from_digest() {
  local digest="$1"
  local sha
  sha="$(echo "${digest}" | sed -n 's/^sha256://p')"
  if [ -z "${sha}" ]; then
    echo "Missing or invalid sha256 digest in GitHub API response" >&2
    exit 1
  fi
  echo "${sha}"
}

setupAsset="breezy_vulkan_setup"
binaryAsset="breezyVulkan-x86_64.tar.gz"
libsAsset="breezyVulkan-libs-x86_64.tar.gz"

setupUrl="$(asset_url "${setupAsset}")"
binaryUrl="$(asset_url "${binaryAsset}")"
libsUrl="$(asset_url "${libsAsset}")"

if [ -z "${setupUrl}" ] || [ -z "${binaryUrl}" ] || [ -z "${libsUrl}" ]; then
  echo "Could not find all expected assets on release ${version}" >&2
  echo "Expected: ${setupAsset}, ${binaryAsset}, ${libsAsset}" >&2
  exit 1
fi

echo "Using setup url: ${setupUrl}"
echo "Using binary url: ${binaryUrl}"
echo "Using libs url: ${libsUrl}"

setupSha256="$(sha256_from_digest "$(asset_digest "${setupAsset}")")"
binarySha256="$(sha256_from_digest "$(asset_digest "${binaryAsset}")")"
libsSha256="$(sha256_from_digest "$(asset_digest "${libsAsset}")")"

if [ -z "${setupSha256}" ] || [ -z "${binarySha256}" ] || [ -z "${libsSha256}" ]; then
  echo "Could not determine sha256 for one or more assets" >&2
  exit 1
fi

echo "Using setup sha256sum: ${setupSha256}"
echo "Using binary sha256sum: ${binarySha256}"
echo "Using libs sha256sum: ${libsSha256}"

# insert the urls and sha256sums into the package.json at the paths like remote_binary[0].url and remote_binary[0].sha256hash
jq --arg binaryUrl "${binaryUrl}" \
   --arg binarySha256 "${binarySha256}" \
   --arg libsUrl "${libsUrl}" \
   --arg libsSha256 "${libsSha256}" \
   --arg setupUrl "${setupUrl}" \
   --arg setupSha256 "${setupSha256}" \
   '.remote_binary[0].url = $setupUrl |
      .remote_binary[0].sha256hash = $setupSha256 |
      .remote_binary[1].url = $binaryUrl |
      .remote_binary[1].sha256hash = $binarySha256 |
      .remote_binary[2].url = $libsUrl |
      .remote_binary[2].sha256hash = $libsSha256' \
    package.json > "${tmpdir}/package.json"

cp "${tmpdir}/package.json" package.json
echo "Copied updated package.json to root of repo"